# =============================================================================
# MetaMaster — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values, then run:
#   docker compose -f docker-compose.example.yml up -d

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Your TMDB Read Access Token (v4 Bearer JWT).
# Get one free at: https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# Absolute paths to your media directories on the host machine.
MOVIE_DIR=/path/to/your/movies
TV_DIR=/path/to/your/tv

# -----------------------------------------------------------------------------
# Optional — defaults shown
# -----------------------------------------------------------------------------

# Postgres password
# POSTGRES_PASSWORD=metamaster

# Log verbosity: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Schedule for the automatic media scan (cron syntax)
# MEDIA_SCAN_SCHEDULE=0 2 * * *

# -----------------------------------------------------------------------------
# Plex Media Server (optional)
# -----------------------------------------------------------------------------
# URL of your Plex server (include port). Required to enable Plex integration.
# PLEX_SERVER_URL=http://192.168.1.x:32400

# Plex authentication token (manual fallback — OAuth flow stores the token in DB).
# Find yours at: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
# PLEX_TOKEN=

# Library section names must match exactly what appears in your Plex UI.
# PLEX_LIBRARY_MOVIES=Movies
# PLEX_LIBRARY_TV=TV Shows

# How often (seconds) the background task polls Plex for watched-status updates.
# PLEX_SYNC_POLL_INTERVAL_SECONDS=300
