# Application Settings
APP_NAME=Media Management Web Tool
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./media.db
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# OMDB API
OMDB_API_KEY=your_omdb_api_key_here
OMDB_RATE_LIMIT=1
OMDB_CACHE_TTL=2592000

# TVDB API
TVDB_API_KEY=your_tvdb_api_key_here
TVDB_PIN=your_tvdb_pin_here
TVDB_RATE_LIMIT=3
TVDB_CACHE_TTL=2592000

# File Monitoring
MEDIA_DIRECTORY=./media
WATCH_EXTENSIONS=.mp4,.mkv,.avi,.mov,.flv,.wmv,.webm,.m4v,.mpg,.mpeg,.3gp

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
