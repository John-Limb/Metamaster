# =============================================================================
# MetaMaster — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values, then run:
#   docker compose -f docker-compose.example.yml up -d

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Your TMDB Read Access Token (v4 Bearer JWT).
# Get one free at: https://www.themoviedb.org/settings/api
TMDB_READ_ACCESS_TOKEN=
TMDB_API_KEY=

# Absolute paths to your media directories on the host machine.
MOVIE_DIR=/path/to/your/movies
TV_DIR=/path/to/your/tv

# -----------------------------------------------------------------------------
# Optional — defaults shown
# -----------------------------------------------------------------------------

# Postgres password
# POSTGRES_PASSWORD=metamaster

# Log verbosity: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Schedule for the automatic media scan (cron syntax)
# MEDIA_SCAN_SCHEDULE=0 2 * * *
